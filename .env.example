# Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED — Supabase
# ============================================
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SITE_URL=https://khedma.tn

# ============================================
# OPTIONAL — Error Tracking (Sentry)
# Only initializes in production mode
# Get your DSN: https://sentry.io → Settings → Client Keys
# ============================================
VITE_SENTRY_DSN=your_sentry_dsn

# ============================================
# OPTIONAL — Analytics (PostHog)
# Only initializes in production mode
# Get your key: https://app.posthog.com → Project Settings
# ============================================
VITE_POSTHOG_KEY=your_posthog_key
VITE_POSTHOG_HOST=https://app.posthog.com

# ============================================
# Edge Functions — set in Supabase dashboard, NOT here
# ============================================
# SUPABASE_SERVICE_ROLE_KEY (auto-set)
# FLOUCI_APP_TOKEN
# FLOUCI_APP_SECRET
# RESEND_API_KEY
# ALLOWED_ORIGIN (e.g., https://khedma-tn.vercel.app)
