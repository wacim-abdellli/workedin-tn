# ================================================
# Khedma TN — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to git
# ================================================

# ---- SUPABASE (Required) ----
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ SECURITY: DO NOT add VITE_SUPABASE_SERVICE_ROLE_KEY here!
# Service role keys bypass all RLS and must NEVER be in frontend code.
# Use Supabase Edge Functions for admin operations instead.

# ---- POSTHOG ANALYTICS (Optional) ----
# Get from: https://posthog.com → Project Settings → API Keys
VITE_POSTHOG_KEY=phc_your_key_here
VITE_POSTHOG_HOST=https://app.posthog.com

# ---- FLOUCI PAYMENT (Optional — for payments) ----
# Only the app token is safe for frontend
# App secret must be set via: supabase secrets set FLOUCI_APP_SECRET=xxx
VITE_FLOUCI_APP_TOKEN=your-flouci-app-token

# ---- SENTRY (Optional — error monitoring) ----
# Get DSN from: https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ---- GOOGLE ANALYTICS (Optional) ----
# Get from: https://analytics.google.com → Admin → Data Streams
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ================================================
# SUPABASE EDGE FUNCTION SECRETS (set via CLI)
# These are server-side only and should NEVER have VITE_ prefix
# 
# Set via: supabase secrets set KEY_NAME=value
# 
# Required secrets:
# - FLOUCI_APP_SECRET (payment processing)
# - RESEND_API_KEY (email sending)
# ================================================
