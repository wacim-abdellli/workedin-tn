# ================================================
# WorkedIn TN — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git (already in .gitignore).
# ================================================

# ---- SUPABASE (Required) ----
# Get from: Supabase Dashboard â†’ Project Settings â†’ API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_IDENTITY_DOCS_BUCKETS=identity-documents,verification-documents

# ---- ANALYTICS (Optional) ----
VITE_POSTHOG_KEY=your-posthog-key
VITE_POSTHOG_HOST=https://app.posthog.com

# ---- SENTRY (Optional â€” error monitoring) ----
# Get DSN from: https://sentry.io â†’ Project Settings â†’ Client Keys
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ---- GOOGLE ANALYTICS (Optional) ----
# Get from: https://analytics.google.com â†’ Admin â†’ Data Streams
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ---- APP URL (used in notifications and meta tags) ----
VITE_APP_URL=https://workedin.tn

# ================================================
# SUPABASE EDGE FUNCTION SECRETS (server-side only)
#
# Payment and email secrets MUST be set as Supabase Edge Function secrets.
# Do NOT add VITE_ prefixed versions of these â€” they have no effect.
#
#   supabase secrets set RESEND_API_KEY=your-resend-key --project-ref <ref>
#   supabase secrets set FLOUCI_APP_TOKEN=your-flouci-token --project-ref <ref>
#   supabase secrets set FLOUCI_APP_SECRET=your-flouci-secret --project-ref <ref>
#
# Admin access is controlled via profiles.is_admin in the database,
# set by a Supabase service-role operation â€” not via a VITE_ variable.
# ================================================



# ================================================
# DHMAD.TN PAYMENT INTEGRATION
# ================================================
