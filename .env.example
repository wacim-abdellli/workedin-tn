# ================================================
# Khedma TN — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to git
# ================================================

# ---- SUPABASE (Required) ----
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ CRITICAL SECURITY WARNING ⚠️
# NEVER add VITE_SUPABASE_SERVICE_ROLE_KEY to .env or any frontend code!
# Service role keys bypass ALL security rules and must ONLY exist in:
# 1. Supabase Edge Functions (set via: supabase secrets set SERVICE_ROLE_KEY=xxx)
# 2. Server-side code (never exposed to browsers)
# Adding it here would expose it to ALL users in the browser!

# ---- FLOUCI PAYMENT (Required for payments) ----
# Get from: https://flouci.com merchant dashboard
VITE_FLOUCI_APP_TOKEN=your-flouci-app-token

# ⚠️ SECURITY: VITE_FLOUCI_APP_SECRET must NEVER be in frontend!
# Set it in Supabase Edge Functions only:
# supabase secrets set FLOUCI_APP_SECRET=your-secret

# ---- POSTHOG ANALYTICS (Optional) ----
# Get from: https://posthog.com → Project Settings → API Keys
VITE_POSTHOG_KEY=phc_your_posthog_key
VITE_POSTHOG_HOST=https://app.posthog.com

# ---- SENTRY (Optional — error monitoring) ----
# Get DSN from: https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ---- GOOGLE ANALYTICS (Optional) ----
# Get from: https://analytics.google.com → Admin → Data Streams
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ---- ADMIN CONFIGURATION (Optional) ----
# Comma-separated list of admin email addresses
VITE_ADMIN_EMAILS=admin@example.com,admin2@example.com

# ---- APP URL (for emails/links) ----
VITE_APP_URL=https://khedma.tn

# ================================================
# SUPABASE EDGE FUNCTION SECRETS (set via CLI)
# These must NEVER be in .env or frontend code!
# ================================================
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# supabase secrets set RESEND_API_KEY=your-resend-key
# supabase secrets set FLOUCI_APP_SECRET=your-flouci-secret
# supabase secrets set FLOUCI_APP_TOKEN=your-flouci-token
# ================================================
