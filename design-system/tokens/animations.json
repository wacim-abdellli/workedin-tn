  "semantic": {
    "hover": {
      "duration": "{duration.fast}",
      "easing": "{easing.ease-out}",
      "description": "Hover state transition"
    },
    "focus": {
      "duration": "{duration.fast}",
      "easing": "{easing.ease-out}",
      "description": "Focus state transition"
    },
    "modal": {
      "duration": "{duration.normal}",
      "easing": "{easing.ease-in-out}",
      "description": "Modal open/close animation"
    },
    "toast": {
      "duration": "{duration.normal}",
      "easing": "{easing.ease-out}",
      "description": "Toast notification animation"
    },
    "page": {
      "duration": "{duration.slow}",
      "easing": "{easing.ease-in-out}",
      "description": "Page transition animation"
