{
  "name": "workedin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:budget": "tsc -b && vite build && node scripts/check-bundle-budgets.mjs",
    "avatar:audit": "node scripts/check-avatar-consistency.mjs",
    "perf:budget": "node scripts/check-bundle-budgets.mjs",
    "lint": "eslint .",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "i18n:audit:strict": "node scripts/i18n-audit.mjs --strict",
    "preview": "vite preview",
    "test": "vitest src design-system/build design-system/scripts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage src design-system/build design-system/scripts",
    "test:run": "vitest run src design-system/build design-system/scripts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:visual": "playwright test e2e/visual-regression.spec.ts --project=chromium-public",
    "test:e2e:visual:update": "playwright test e2e/visual-regression.spec.ts --project=chromium-public --update-snapshots",
    "test:e2e:a11y:strict": "playwright test e2e/auth-protection-a11y.spec.ts e2e/a11y-matrix.spec.ts --project=chromium-public",
    "tokens:compliance": "node scripts/check-design-token-compliance.mjs --output artifacts/design-token-compliance/report.json",
    "headers:verify": "node scripts/verify-security-headers.mjs",
    "deps:audit": "node scripts/dependency-audit.mjs --fail-on high --output artifacts/dependency-audit/report.json",
    "release:control": "node scripts/release-control.mjs",
    "audit:strict": "npm run lint && npm run avatar:audit && npm run i18n:audit:strict && npm run test:run && npm run build:budget && npm run test:e2e:a11y:strict",
    "tokens:compile": "node design-system/build/token-compiler.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/react": "^10.46.0",
    "@supabase/supabase-js": "^2.93.1",
    "@tanstack/react-query": "^5.95.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/dompurify": "^3.0.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.29.2",
    "i18next": "^25.8.0",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^0.563.0",
    "posthog-js": "^1.335.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^14.3.8",
    "react-error-boundary": "^6.1.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.4",
    "react-intersection-observer": "^10.0.2",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.4.2",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "vitest": {
      "vite": "6.4.2"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
