# Flouci Payment Gateway Environment Variables
# Copy this file to .env and fill in your credentials

# Flouci API URL (use sandbox for testing)
VITE_FLOUCI_API_URL=https://developers.flouci.com/api

# Your Flouci App Token (from merchant dashboard)
VITE_FLOUCI_APP_TOKEN=your_app_token_here

# Your Flouci App Secret (server-side only — set via Supabase Edge Function secrets)
# DO NOT prefix with VITE_ — Vite exposes all VITE_* vars to the browser bundle
FLOUCI_APP_SECRET=your_app_secret_here

# ── DHMAD Escrow Gateway ──────────────────────────────────────────────────────
# Set these as Supabase Edge Function secrets (never expose in frontend):
#   npx supabase secrets set DHMAD_API_KEY=sk_live_... --project-ref <ref>
#   npx supabase secrets set DHMAD_BASE_URL=https://dhmad.tn/api/v1 --project-ref <ref>
#   npx supabase secrets set ALLOWED_ORIGIN=https://workedin.tn --project-ref <ref>
#
# Sandbox: use sk_sandbox_... key + https://sandbox.dhmad.tn/api/v1
DHMAD_API_KEY=sk_live_...
DHMAD_BASE_URL=https://dhmad.tn/api/v1
DHMAD_CHECKOUT_BASE=https://dhmad.tn/checkout
ALLOWED_ORIGIN=https://workedin.tn
